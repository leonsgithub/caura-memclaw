    "title": null,
    "description": "Report the outcome of following a procedure. procedure_id = the id from a memclaw_procedure_suggest result; outcome_type: success|failure. Updates the procedure's reliability_score and quarantines it once it has \u22653 attempts and a score below 0.3 (after which it stops being suggested). Optional request_id (from suggest), latency_ms, and validation_passed are recorded for telemetry. Trust \u2265 1 \u2014 agents can only record against procedures in their own tenant.",
    "inputSchema": {
      "properties": {
        "procedure_id": {
          "description": "The procedure's id, from a memclaw_procedure_suggest result.",
          "title": "Procedure Id",
          "type": "string"
        },
        "outcome_type": {
          "description": "success | failure.",
          "title": "Outcome Type",
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "request_id from suggest (telemetry correlation).",
          "title": "Request Id"
        },
        "latency_ms": {
          "anyOf": [
            {
              "type": "integer"
